# Training logs (but keep benchmark checkpoints)
*.log

# Uncomment to ignore all benchmarks (if you don't want to commit trained models):
# benchmarks/
# benchmark_results/

# Checkpoints (except for release checkpoints)
checkpoints/

# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.so

# Testing
.pytest_cache/
.coverage
htmlcov/

# IDEs
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Temporary files
*.tmp
*.bak

# Documentation archive (internal development notes)
docs/archive/

# Checkpoints from user training (keep benchmarks/ for pre-trained models)
checkpoints/*
!checkpoints/.gitkeep
